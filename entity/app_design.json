{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_collection_job",
            "entity_type": "JOB",
            "entity_source": "SCHEDULED",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "data_collection_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "download_london_houses_data",
                        "description": "Download London Houses Data from the specified source.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data collection.",
                        "end_state": "data_downloaded",
                        "end_state_description": "London Houses Data has been successfully downloaded.",
                        "process": {
                            "name": "download_data_process",
                            "description": "Process to download data from the specified source.",
                            "adds_new_entites": "london_houses_raw_data"
                        }
                    },
                    {
                        "name": "analyze_london_houses_data",
                        "description": "Analyze the downloaded London Houses Data using pandas.",
                        "start_state": "data_downloaded",
                        "start_state_description": "Data has been downloaded and is ready for analysis.",
                        "end_state": "data_analyzed",
                        "end_state_description": "Data analysis has been successfully completed.",
                        "process": {
                            "name": "analyze_data_process",
                            "description": "Process to analyze downloaded data using pandas.",
                            "adds_new_entites": "london_houses_analysis_result"
                        }
                    },
                    {
                        "name": "generate_report",
                        "description": "Generate a report based on the analysis results.",
                        "start_state": "data_analyzed",
                        "start_state_description": "Data analysis is completed and ready for reporting.",
                        "end_state": "report_generated",
                        "end_state_description": "Report has been successfully generated.",
                        "process": {
                            "name": "generate_report_process",
                            "description": "Process to create a report from the analysis result.",
                            "adds_new_entites": "london_houses_report"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "london_houses_raw_data",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_collection_job",
            "entity_workflow": {
                "name": "london_houses_raw_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "london_houses_analysis_result",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_collection_job",
            "entity_workflow": {
                "name": "london_houses_analysis_result_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "london_houses_report",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_collection_job",
            "entity_workflow": {
                "name": "london_houses_report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}