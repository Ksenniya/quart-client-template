{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "depends_on_entity": "None",
            "entity_name": "data_ingestion_job",
            "entity_source": "SCHEDULED",
            "entity_type": "JOB",
            "entity_workflow": {
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "name": "data_ingestion_workflow",
                "transitions": [
                    {
                        "name": "scheduled_ingestion",
                        "description": "Start the data ingestion process from the API.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data ingestion.",
                        "end_state": "data_ingested",
                        "end_state_description": "Data has been successfully ingested.",
                        "process": {
                            "name": "ingest_raw_data",
                            "description": "Process to ingest raw data from the specified API.",
                            "adds_new_entites": "raw_data_entity"
                        }
                    },
                    {
                        "name": "analyze_data",
                        "description": "Analyze the ingested data using pandas.",
                        "start_state": "data_ingested",
                        "start_state_description": "Data has been ingested and is ready for analysis.",
                        "end_state": "data_analyzed",
                        "end_state_description": "Data has been successfully analyzed.",
                        "process": {
                            "name": "analyze_raw_data",
                            "description": "Process to analyze raw data using pandas.",
                            "adds_new_entites": "analysis_report_entity"
                        }
                    },
                    {
                        "name": "generate_report",
                        "description": "Generate and save a report from the analyzed data.",
                        "start_state": "data_analyzed",
                        "start_state_description": "Data has been analyzed and report generation is commencing.",
                        "end_state": "report_generated",
                        "end_state_description": "Report has been successfully generated and saved.",
                        "process": {
                            "name": "generate_report",
                            "description": "Process to generate a report from the analysis.",
                            "adds_new_entites": "report_entity"
                        }
                    }
                ]
            }
        },
        {
            "depends_on_entity": "data_ingestion_job",
            "entity_name": "raw_data_entity",
            "entity_source": "ENTITY_EVENT",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_workflow": {
                "name": "raw_data_entity_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "depends_on_entity": "data_ingestion_job",
            "entity_name": "analysis_report_entity",
            "entity_source": "ENTITY_EVENT",
            "entity_type": "SECONDARY_DATA",
            "entity_workflow": {
                "name": "analysis_report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "depends_on_entity": "data_ingestion_job",
            "entity_name": "report_entity",
            "entity_source": "ENTITY_EVENT",
            "entity_type": "SECONDARY_DATA",
            "entity_workflow": {
                "name": "report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}