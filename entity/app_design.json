{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_ingestion_job",
            "entity_type": "JOB",
            "entity_source": "SCHEDULED",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "data_ingestion_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "scheduled_ingestion",
                        "description": "Start the data ingestion process for London Houses Data.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data ingestion.",
                        "end_state": "data_ingested",
                        "end_state_description": "Data has been successfully ingested.",
                        "process": {
                            "name": "ingest_raw_data",
                            "description": "Process to ingest London Houses Data from the specified source.",
                            "adds_new_entites": "raw_london_houses_data"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "raw_london_houses_data",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "raw_london_houses_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "analyzed_london_houses_data",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "analyzed_london_houses_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "analyze_london_houses_data",
                        "description": "Analyze the raw London Houses Data using pandas.",
                        "start_state": "data_ingested",
                        "start_state_description": "Data has been successfully ingested and is ready for analysis.",
                        "end_state": "data_analyzed",
                        "end_state_description": "Data has been successfully analyzed.",
                        "process": {
                            "name": "analyze_data",
                            "description": "Function to analyze the raw data.",
                            "adds_new_entites": "report_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "analyzed_london_houses_data",
            "entity_workflow": {
                "name": "report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "generate_report",
                        "description": "Generate a report from the analyzed data.",
                        "start_state": "data_analyzed",
                        "start_state_description": "The data has been analyzed and is ready for reporting.",
                        "end_state": "report_generated",
                        "end_state_description": "The report has been successfully generated.",
                        "process": {
                            "name": "generate_report",
                            "description": "Process to create a report from analyzed data.",
                            "adds_new_entites": "final_report"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "final_report",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "report_entity",
            "entity_workflow": {
                "name": "final_report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}