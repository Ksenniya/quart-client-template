{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cyoda design",
    "type": "object",
    "entities": [
        {
            "entity_name": "data_ingestion_job",
            "entity_type": "JOB",
            "entity_source": "SCHEDULED",
            "depends_on_entity": "None",
            "entity_workflow": {
                "name": "data_ingestion_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": [
                    {
                        "name": "ingest_london_houses_data",
                        "description": "Ingest London Houses Data from the specified source.",
                        "start_state": "None",
                        "start_state_description": "Initial state before data ingestion.",
                        "end_state": "data_ingested",
                        "end_state_description": "London Houses Data has been successfully ingested.",
                        "process": {
                            "name": "ingest_raw_data_process",
                            "description": "Process to ingest raw data for London Houses.",
                            "adds_new_entites": "raw_london_houses_data_entity"
                        }
                    },
                    {
                        "name": "analyze_data",
                        "description": "Analyze the ingested London Houses Data.",
                        "start_state": "data_ingested",
                        "start_state_description": "Data has been ingested and is ready for analysis.",
                        "end_state": "data_analyzed",
                        "end_state_description": "London Houses Data has been successfully analyzed.",
                        "process": {
                            "name": "analyze_data_process",
                            "description": "Process to analyze London Houses Data using pandas.",
                            "adds_new_entites": "analyzed_london_houses_data_entity"
                        }
                    },
                    {
                        "name": "generate_report",
                        "description": "Generate a report based on the analyzed data.",
                        "start_state": "data_analyzed",
                        "start_state_description": "Data has been analyzed and is ready for reporting.",
                        "end_state": "report_generated",
                        "end_state_description": "Report has been successfully generated.",
                        "process": {
                            "name": "generate_report_process",
                            "description": "Process to create a report for London Houses Data analysis.",
                            "adds_new_entites": "report_entity"
                        }
                    }
                ]
            }
        },
        {
            "entity_name": "raw_london_houses_data_entity",
            "entity_type": "EXTERNAL_SOURCES_PULL_BASED_RAW_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "raw_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "analyzed_london_houses_data_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "analyzed_data_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        },
        {
            "entity_name": "report_entity",
            "entity_type": "SECONDARY_DATA",
            "entity_source": "ENTITY_EVENT",
            "depends_on_entity": "data_ingestion_job",
            "entity_workflow": {
                "name": "report_workflow",
                "class_name": "com.cyoda.tdb.model.treenode.TreeNodeEntity",
                "transitions": []
            }
        }
    ]
}